{
  "name": "pathtex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "deploy:commands": "tsx scripts/deploy-commands.ts",
    "dev": "tsx src/index.ts",
    "format": "prettier --write package.json tsconfig.json tsconfig.test.json .prettierrc eslint.config.js src tests scripts docker-compose.yml .github/workflows/ci.yml scripts/log-preview.ts",
    "format:check": "prettier --check package.json tsconfig.json tsconfig.test.json .prettierrc eslint.config.js src tests scripts docker-compose.yml .github/workflows/ci.yml scripts/log-preview.ts",
    "lint": "eslint . --max-warnings=0",
    "predev": "corepack pnpm prisma:generate",
    "prestart": "corepack pnpm prisma:generate",
    "prisma:generate": "prisma generate",
    "start": "node dist/index.js",
    "log-preview": "tsx scripts/log-preview.ts",
    "test": "vitest run tests --exclude tests/integration/**",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run tests/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "@prisma/client": "^6.19.0",
    "discord.js": "^14.26.0",
    "dotenv": "^16.6.1",
    "i18next": "^26.3.6",
    "luxon": "^3.7.2",
    "pino": "^9.9.0",
    "re2": "^1.22.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.18.6",
    "@testcontainers/postgresql": "^11.5.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "undici@<6.27.0": ">=6.27.0 <7.0.0"
    }
  }
}
